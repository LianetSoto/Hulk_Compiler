// Range type that implements the Iterable protocol
type Range(min: Number, max: Number) {
    min = min;
    max = max;
    current = min - 1;

    // next() method: updates current and returns true if more elements remain
    next(): Boolean {
        self.current := self.current + 1;
        self.current < self.max
    }

    // current() method: returns the current value (Number, a subtype of Object)
    current(): Number => self.current;
}

// Global function to easily create a Range instance
function iterable(min: Number, max: Number): Number* => new Range(min, max);

// Iterate over a Range and print the numbers
let r : Number* = iterable(1, 6) in {
    for (x in r) {
        print(x);   // Prints 1, 2, 3, 4, 5
    }
}
// ============================================================
// Test: variable binding, nested scopes, shadowing and assignment
// ============================================================

// 1. Simple variable with a string literal
let msg = "Hello World" in print(msg);
print(" ");

// 2. Multiple bindings – later initializers see earlier variables
let a = 6, b = a * 7 in print(b);
print(" ");

// 3. Nested let expressions
let a = 6 in
let b = a * 7 in
print(b);
print(" ");

4. Multiple variables with an expression block body
let a = 5, b = 10, c = 20 in {
    print(a + b);
    print(b * c);
    print(c / a);
};
print(" ");

// 5. A let expression used as an initializer
let a = (let b = 6 in b * 7) in print(a);
print(" ");

// 6. Printing a let expression directly
print(let b = 6 in b * 7);
print(" ");

// 7. Shadowing – inner binding hides the outer one
let a = 20 in {
    let a = 42 in print(a);   // expected: 42
    print(a);                 // expected: 20
};
print(" ");

// 8. Destructive assignment (:=)
let a = 0 in {
    print(a);      // expected: 0
    a := 1;
    print(a);      // expected: 1
};

let a = 0 in
let b = a := 1 in {
print(a);   //expected: 1 
print(b);   //expected: 1
};

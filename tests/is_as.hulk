// Test: is / as operators

type Animal { }

type Perro inherits Animal {
    ladrar() => print("Guau!");
}

type Gato inherits Animal {
    maullar() => print("Meow!");
}

{
    // is with inheritance
    let a : Animal = new Perro() in {
        print(a is Animal);    // true  (Perro is an Animal)
        print(a is Perro);     // true  (a is actually a Perro)
        print(a is Gato);      // false (Perro is not a Gato)
    };

    // is with unrelated types
    let p = new Perro() in {
        print(p is Gato);      // false (unrelated)
        print(p is Animal);    // true  (inheritance)
    };

    // successful as (safe downcast)
    let b : Animal = new Perro() in 
        if (b is Perro) 
            {
                let p : Perro = b as Perro in
                p.ladrar();              // "Guau!"
               
            }
        else print("B no es perro");
    

    // as used directly in an expression
    let c : Animal = new Gato() in
        (c as Gato).maullar();       // "Meow!"
}
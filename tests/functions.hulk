function add(x, y) => x + y;
print(add(5,3));

function factorial(n) => if (n <= 1) 1 else n * factorial(n - 1);
function operate(x, y) {
  print(x + y);
  print(x - y);
  print(x * y);
  print(x / y);
};

function square(x) => x * x;
function cube(x) => x * x * x;
function sumOfPowers(x, y) => square(x) + cube(y);
function sin(x) => x - x * x * x / 6;
function cos(x) => 1 - x * x / 2;

function distance(x1, y1, x2, y2) => 
  let dx = x2 - x1, dy = y2 - y1 
  in (dx * dx + dy * dy) ^ 0.5;

function getPI() => PI;
function getE() => E;

function checkPositive(x) {
  if (x > 0) 
    print("Positive")
  else 
    print("Not positive")
};

function tan(x) => sin(x) / cos(x);
function cot(x) => 1 / tan(x);
print(tan(PI / 4) ^ 2 + cot(PI / 4) ^ 2);

function fibonacci(n) => 
  if (n <= 1) 
    n 
  else 
    fibonacci(n - 1) + fibonacci(n - 2);

function computeRange(start, end) {
  for (i in range(start, end)) {
    print(fibonacci(i));
  }
}

// Bloque principal con todas las expresiones a ejecutar
{
  print(add(5, 3));
  print(factorial(5));
  operate(10, 2);
  print(sumOfPowers(3, 2));
  print(tan(PI / 4));
  print(distance(0, 0, 3, 4));
  print(getPI() + getE());
  checkPositive(5);
  checkPositive(-3);
  print(tan(PI / 4) ^ 2 + cot(PI / 4) ^ 2);
  computeRange(1, 8);
}